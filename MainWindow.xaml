<Window x:Class="EkipppOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EkipppOptimizer.ViewModels"
        xmlns:svc="clr-namespace:EkipppOptimizer.Services"
        xmlns:local="clr-namespace:EkipppOptimizer"
        Title="EKIPPP OPTIMIZER"
        Width="1260" Height="820"
        MinWidth="1000" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"      Color="#0F0A18"/>
        <SolidColorBrush x:Key="BgSidebar"   Color="#0A0612"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1A1028"/>
        <SolidColorBrush x:Key="BgCard2"     Color="#130E1F"/>
        <SolidColorBrush x:Key="Accent"      Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentLight" Color="#A78BFA"/>
        <SolidColorBrush x:Key="TxtPrimary"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TxtSecond"   Color="#D4C6F0"/>
        <SolidColorBrush x:Key="TxtMuted"    Color="#C2B5E0"/>
        <SolidColorBrush x:Key="Success"     Color="#22C55E"/>
        <SolidColorBrush x:Key="Warning"     Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger"      Color="#EF4444"/>
        <SolidColorBrush x:Key="Border1"     Color="#2D1F45"/>

        <local:InvertBoolConverter      x:Key="InvBool"/>
        <local:SizeConverter            x:Key="SzConv"/>
        <local:BoolToTextConverter      x:Key="BoolText"/>
        <local:PercentToWidthConverter  x:Key="PctWidth"/>
        <local:PercentToHeightConverter x:Key="PctHeight"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Style global ProgressBar — dark theme, coins arrondis -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background"      Value="#1A1028"/>
            <Setter Property="Foreground"      Value="#7C3AED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Grid x:Name="PART_Track">
                                <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="Foreground"          Value="#A898C8"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Height"              Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"             Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2">
                            <Grid>
                                <Rectangle x:Name="Bar" Width="3" HorizontalAlignment="Left"
                                           RadiusX="1.5" RadiusY="1.5"
                                           Fill="Transparent" Margin="0,9"/>
                                <ContentPresenter VerticalAlignment="Center" Margin="14,0,10,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"  Property="Background" Value="#110C20"/>
                                <Setter Property="Foreground"                   Value="#D0C0F0"/>
                                <Setter TargetName="Bar" Property="Fill"        Value="#3D2860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button">
            <Setter Property="Background"          Value="#1C1038"/>
            <Setter Property="Foreground"          Value="{StaticResource AccentLight}"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Height"              Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"             Value="0"/>
            <Setter Property="FontWeight"          Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2">
                            <Grid>
                                <Rectangle Width="3" HorizontalAlignment="Left"
                                           RadiusX="1.5" RadiusY="1.5"
                                           Fill="{StaticResource Accent}" Margin="0,9"/>
                                <ContentPresenter VerticalAlignment="Center" Margin="14,0,10,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"     Value="12"/>
            <Setter Property="Padding"          Value="20,16"/>
            <Setter Property="Margin"           Value="0,0,0,12"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border1}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#4A3270"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallCard" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="14,12"/>
            <Setter Property="Margin"           Value="0,0,0,0"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border1}"/>
            <Setter Property="BorderThickness"  Value="1"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <SolidColorBrush x:Name="BtnBg" Color="#7C3AED"/>
                            </Border.Background>
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextOptions.TextRenderingMode="ClearType"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="BtnHoverOn">
                                        <Storyboard FillBehavior="HoldEnd">
                                            <ColorAnimation Storyboard.TargetName="BtnBg" Storyboard.TargetProperty="Color"
                                                            To="#6D28D9" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="BtnHoverOn"/>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="HoldEnd">
                                            <ColorAnimation Storyboard.TargetName="BtnBg" Storyboard.TargetProperty="Color"
                                                            To="#7C3AED" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Background"   Value="#1E1232"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentLight}"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="16,9"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="{StaticResource Accent}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextOptions.TextRenderingMode="ClearType"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D1B4E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Foreground"   Value="{StaticResource TxtPrimary}"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track" Width="44" Height="24" CornerRadius="12" BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush x:Name="TrackBg" Color="#1E1232"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="TrackBd" Color="#2D1F45"/>
                                </Border.BorderBrush>
                                <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9"
                                        Margin="3,0,0,0" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="ThumbBg" Color="#8B7AB8"/>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- Position : changement instantané (fiable pour l'état initial) -->
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                <!-- Couleurs : transition fluide -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ToggleOnSB">
                                        <Storyboard FillBehavior="HoldEnd">
                                            <ColorAnimation Storyboard.TargetName="TrackBg" Storyboard.TargetProperty="Color" To="#4C1D95" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBd" Storyboard.TargetProperty="Color" To="#7C3AED" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbBg" Storyboard.TargetProperty="Color" To="#A78BFA" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="ToggleOnSB"/>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="HoldEnd">
                                            <ColorAnimation Storyboard.TargetName="TrackBg" Storyboard.TargetProperty="Color" To="#1E1232" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBd" Storyboard.TargetProperty="Color" To="#2D1F45" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="ThumbBg" Storyboard.TargetProperty="Color" To="#8B7AB8" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5A4878"/>
            <Setter Property="Margin"     Value="18,18,12,4"/>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TxtPrimary}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PageSub" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TxtSecond}"/>
            <Setter Property="Margin"     Value="0,0,0,20"/>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TxtSecond}"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="LogBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#0A0612"/>
            <Setter Property="Foreground"       Value="#A0F080"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border1}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12"/>
            <Setter Property="IsReadOnly"       Value="True"/>
            <Setter Property="TextWrapping"     Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MinHeight"        Value="200"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3D2A5E" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TxtPrimary}"/>
            <Setter Property="Padding"     Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#0D0920"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="None"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Foreground"               Value="{StaticResource TxtPrimary}"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="SelectionMode"            Value="Single"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#0A0612"/>
            <Setter Property="Foreground"      Value="{StaticResource TxtMuted}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TxtPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="10,6" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1232"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="{StaticResource BgMain}" CornerRadius="14"
            BorderBrush="#2D1B4E" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="#0A0612" CornerRadius="14,14,0,0"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                        <Image Source="pack://application:,,,/Assets/logo.png" Width="28" Height="28" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="EKIPPP" FontSize="15" FontWeight="Black"
                                   Foreground="{StaticResource AccentLight}" VerticalAlignment="Center"/>
                        <TextBlock Text=" OPTIMIZER" FontSize="15" FontWeight="Light"
                                   Foreground="{StaticResource TxtSecond}" VerticalAlignment="Center"/>
                        <Border Background="#2D1B4E" CornerRadius="4" Padding="6,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding VersionDisplay}" FontSize="10" Foreground="{StaticResource AccentLight}" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                        <Button Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Click="MinimizeClick" Cursor="Hand" ToolTip="Réduire">
                            <TextBlock Text="─" Foreground="{StaticResource TxtSecond}" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnFullscreen" Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Click="FullscreenClick" Cursor="Hand" ToolTip="Plein écran / Fenêtré">
                            <TextBlock x:Name="FullscreenIcon" Text="⛶" Foreground="{StaticResource TxtSecond}" FontSize="13"/>
                        </Button>
                        <Button Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Click="CloseClick" Cursor="Hand" ToolTip="Fermer">
                            <TextBlock Text="✕" Foreground="{StaticResource TxtSecond}" FontSize="13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource BgSidebar}"
                        BorderBrush="#1A0F2E" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,6,0,20">

                            <!-- ── PRINCIPAL ─────────────────────────────── -->
                            <TextBlock Text="PRINCIPAL" Style="{StaticResource SectionTitle}"/>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn0"
                                    Command="{Binding SelectTabCommand}" CommandParameter="0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◉" Width="20" FontSize="13"
                                               Foreground="#A78BFA" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn1"
                                    Command="{Binding SelectTabCommand}" CommandParameter="1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◈" Width="20" FontSize="13"
                                               Foreground="#A78BFA" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nettoyage" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn2"
                                    Command="{Binding SelectTabCommand}" CommandParameter="2">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="▸" Width="20" FontSize="14"
                                               Foreground="#A78BFA" VerticalAlignment="Center"/>
                                    <TextBlock Text="Démarrage" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── SYSTÈME ────────────────────────────────── -->
                            <Border Height="1" Background="#1A1028" Margin="12,6,12,0"/>
                            <TextBlock Text="SYSTÈME" Style="{StaticResource SectionTitle}"/>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn3"
                                    Command="{Binding SelectTabCommand}" CommandParameter="3">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◎" Width="20" FontSize="13"
                                               Foreground="#60A5FA" VerticalAlignment="Center"/>
                                    <TextBlock Text="Réseau" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn4"
                                    Command="{Binding SelectTabCommand}" CommandParameter="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="▤" Width="20" FontSize="13"
                                               Foreground="#60A5FA" VerticalAlignment="Center"/>
                                    <TextBlock Text="Stockage" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn5"
                                    Command="{Binding SelectTabCommand}" CommandParameter="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✱" Width="20" FontSize="13"
                                               Foreground="#60A5FA" VerticalAlignment="Center"/>
                                    <TextBlock Text="Pilotes" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn6"
                                    Command="{Binding SelectTabCommand}" CommandParameter="6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⚠" Width="20" FontSize="12"
                                               Foreground="#F59E0B" VerticalAlignment="Center"/>
                                    <TextBlock Text="Problèmes" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    <Border Background="#3D1A0A" CornerRadius="8" Padding="6,1" Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasCriticalIssues, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding CriticalCount}" FontSize="10"
                                                   FontWeight="Bold" Foreground="#F87171"/>
                                    </Border>
                                </StackPanel>
                            </Button>

                            <!-- ── OPTIMISATION ───────────────────────────── -->
                            <Border Height="1" Background="#1A1028" Margin="12,6,12,0"/>
                            <TextBlock Text="OPTIMISATION" Style="{StaticResource SectionTitle}"/>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn7"
                                    Command="{Binding SelectTabCommand}" CommandParameter="7">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◐" Width="20" FontSize="13"
                                               Foreground="#34D399" VerticalAlignment="Center"/>
                                    <TextBlock Text="Profils" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn8"
                                    Command="{Binding SelectTabCommand}" CommandParameter="8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◆" Width="20" FontSize="12"
                                               Foreground="#34D399" VerticalAlignment="Center"/>
                                    <TextBlock Text="Gaming" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn9"
                                    Command="{Binding SelectTabCommand}" CommandParameter="9">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◍" Width="20" FontSize="13"
                                               Foreground="#34D399" VerticalAlignment="Center"/>
                                    <TextBlock Text="Confidentialité" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ── AVANCÉ ─────────────────────────────────── -->
                            <Border Height="1" Background="#1A1028" Margin="12,6,12,0"/>
                            <TextBlock Text="AVANCÉ" Style="{StaticResource SectionTitle}"/>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn10"
                                    Command="{Binding SelectTabCommand}" CommandParameter="10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⊕" Width="20" FontSize="13"
                                               Foreground="#FB923C" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sécurité" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn11"
                                    Command="{Binding SelectTabCommand}" CommandParameter="11">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="◌" Width="20" FontSize="13"
                                               Foreground="#FB923C" VerticalAlignment="Center"/>
                                    <TextBlock Text="Automatisation" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" x:Name="Btn12"
                                    Command="{Binding SelectTabCommand}" CommandParameter="12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✕" Width="20" FontSize="12"
                                               Foreground="#FB923C" VerticalAlignment="Center"/>
                                    <TextBlock Text="Désinstalleur" FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                    <!-- Version -->
                    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#1A0F2E" Padding="0,8,0,10">
                        <TextBlock Text="{Binding VersionDisplay}" FontSize="10" Foreground="#3D2B5E"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    </Grid>
                </Border>

                <!-- CONTENT PANELS -->
                <Grid Grid.Column="1">

                    <!-- TAB 0 — DASHBOARD -->
                    <ScrollViewer x:Name="Tab0Panel" Visibility="Visible"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,20,28,24">

                            <!-- HEADER -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Tableau de bord" Style="{StaticResource PageTitle}"/>
                                    <TextBlock Text="{Binding OsSummary}" Foreground="{StaticResource TxtMuted}"
                                               FontSize="13" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"
                                               Foreground="{StaticResource TxtMuted}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Analyse…"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnalyzing}" Value="False">
                                                        <Setter Property="Text" Value=""/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Style="{StaticResource SecBtn}" Padding="12,6"
                                            Command="{Binding RunAnalysisCommand}"
                                            IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InvBool}}"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="↻" FontSize="15" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Actualiser" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Disclaimer honnête -->
                            <Border Background="#120D1F" BorderBrush="#3D2B5E" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ" FontSize="18" Foreground="#A78BFA"
                                               VerticalAlignment="Top" Margin="0,1,12,0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}">À savoir — </Run>
                                        <Run>Aucun logiciel ne peut garantir un gain chiffré de FPS. EKIPPP OPTIMIZER optimise les conditions de votre PC : nettoyage en profondeur, libération de RAM, suppression des processus parasites, fermeture des overlays et application de tweaks Windows reconnus. Les résultats dépendent de votre configuration. L'app vous fait gagner du temps et simplifie en quelques clics des optimisations qui prendraient des heures manuellement.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Bannière admin (masquée si admin) -->
                            <Border Background="#1A0D00" BorderBrush="#92400E" BorderThickness="1"
                                    CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdmin}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="⚠ Droits administrateur requis pour certaines fonctions"
                                                   FontWeight="Bold" Foreground="#FBBF24" FontSize="13"/>
                                        <TextBlock Foreground="#D97706" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"
                                                   Text="DNS, TRIM, netsh, plans d'alimentation nécessitent les droits admin. Relancez l'app en tant qu'administrateur pour un accès complet."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Relancer en admin"
                                            Command="{Binding RestartAsAdminCommand}"
                                            Style="{StaticResource SecBtn}" Margin="12,0,0,0" VerticalAlignment="Center"
                                            ToolTip="Ferme et relance l'application avec les droits administrateur"/>
                                </Grid>
                            </Border>

                            <!-- ══ OPTIMISATION 1 CLIC ═══════════════════════════ -->
                            <Border BorderBrush="#7C3AED" BorderThickness="1"
                                    CornerRadius="12" Margin="0,0,0,16" Padding="20,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1028" Offset="0"/>
                                        <GradientStop Color="#0F0D1E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="OPTIMISATION EN 1 CLIC" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding OneClickStatus}" FontSize="13" Foreground="{StaticResource TxtSecond}"
                                                   TextWrapping="Wrap" MaxWidth="600"/>
                                        <TextBlock Text="{Binding OneClickBeforeAfter}" FontSize="12" Foreground="{StaticResource AccentLight}"
                                                   Margin="0,4,0,0" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OneClickBeforeAfter}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OneClickBeforeAfter}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Width="180" Height="52"
                                            Command="{Binding OneClickOptimizeCommand}"
                                            IsEnabled="{Binding IsOneClickBusy, Converter={StaticResource InvBool}}"
                                            ToolTip="Lance une optimisation complète : nettoyage, TCP, TRIM, RAM, profil Gaming">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                                            <GradientStop Color="#5B21B6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="10" Padding="16,10">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⚡ Optimiser"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOneClickBusy}" Value="True">
                                                                <Setter Property="Text" Value="⏳ En cours…"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="en 1 clic" FontSize="11" FontWeight="Normal"
                                                       TextAlignment="Center" Foreground="#C4B5FD"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- 4 JAUGES CIRCULAIRES -->
                            <UniformGrid Columns="4" Margin="0,0,0,16">
                                <local:CircularGauge Value="{Binding MonCpuPercent}"
                                                     Title="PROCESSEUR"
                                                     Subtitle="{Binding CpuSummary}"
                                                     Margin="0,0,6,0"/>
                                <local:CircularGauge Value="{Binding MonRamPercent}"
                                                     Title="MÉMOIRE VIVE"
                                                     Margin="6,0,6,0">
                                    <local:CircularGauge.ArcBrush>
                                        <SolidColorBrush Color="#22C55E"/>
                                    </local:CircularGauge.ArcBrush>
                                    <local:CircularGauge.Subtitle>
                                        <Binding Path="MonRamUsedGB" StringFormat="{}{0:F1} Go utilisés"/>
                                    </local:CircularGauge.Subtitle>
                                </local:CircularGauge>
                                <local:CircularGauge Value="{Binding MonDiskCPercent}"
                                                     Title="DISQUE C:"
                                                     Subtitle="{Binding DiskSummary}"
                                                     Margin="6,0,6,0">
                                    <local:CircularGauge.ArcBrush>
                                        <SolidColorBrush Color="#F59E0B"/>
                                    </local:CircularGauge.ArcBrush>
                                </local:CircularGauge>
                                <local:CircularGauge Value="{Binding MonNetPercent}"
                                                     Title="RÉSEAU"
                                                     Subtitle="{Binding MonNetLabel}"
                                                     CenterText="{Binding MonNetCenter}"
                                                     Margin="6,0,0,0">
                                    <local:CircularGauge.ArcBrush>
                                        <SolidColorBrush Color="#06B6D4"/>
                                    </local:CircularGauge.ArcBrush>
                                </local:CircularGauge>
                            </UniformGrid>

                            <!-- SURVEILLANCE EN TEMPS RÉEL -->
                            <TextBlock Text="SURVEILLANCE EN TEMPS RÉEL" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                            <UniformGrid Columns="2" Margin="0,0,0,16">

                                <!-- CPU -->
                                <Border Style="{StaticResource SmallCard}" Margin="0,0,6,6" Padding="18,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="56"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="PROCESSEUR" Style="{StaticResource MetricLabel}" Margin="0"/>
                                                <TextBlock Text="{Binding MonCpuPercent, StringFormat={}{0:F0}%}"
                                                           FontSize="32" FontWeight="Black" Foreground="{StaticResource AccentLight}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CpuSummary}" Foreground="{StaticResource TxtMuted}"
                                                       FontSize="13" VerticalAlignment="Bottom" Margin="12,0,0,6"
                                                       TextWrapping="Wrap" MaxWidth="220"/>
                                        </StackPanel>
                                        <local:SparklineChart Grid.Row="2" Height="56"
                                                              LatestValue="{Binding MonCpuPercent}"/>
                                    </Grid>
                                </Border>

                                <!-- RAM -->
                                <Border Style="{StaticResource SmallCard}" Margin="6,0,0,6" Padding="18,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="56"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="MÉMOIRE" Style="{StaticResource MetricLabel}" Margin="0"/>
                                                <TextBlock Text="{Binding MonRamPercent, StringFormat={}{0:F0}%}"
                                                           FontSize="32" FontWeight="Black" Foreground="#22C55E"/>
                                            </StackPanel>
                                            <TextBlock Foreground="{StaticResource TxtMuted}" FontSize="13"
                                                       VerticalAlignment="Bottom" Margin="12,0,0,6">
                                                <Run Text="{Binding MonRamUsedGB, StringFormat={}{0:F1} Go}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding MonRamTotalGB, StringFormat={}{0:F1} Go}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <local:SparklineChart Grid.Row="2" Height="56"
                                                              LatestValue="{Binding MonRamPercent}">
                                            <local:SparklineChart.StrokeBrush>
                                                <SolidColorBrush Color="#22C55E"/>
                                            </local:SparklineChart.StrokeBrush>
                                        </local:SparklineChart>
                                    </Grid>
                                </Border>

                                <!-- RÉSEAU -->
                                <Border Style="{StaticResource SmallCard}" Margin="0,0,6,0" Padding="18,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="56"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="RÉSEAU" Style="{StaticResource MetricLabel}" Margin="0"/>
                                                <TextBlock Text="{Binding MonNetLabel}"
                                                           FontSize="22" FontWeight="Black" Foreground="#06B6D4"/>
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Bottom" Margin="12,0,0,6">
                                                <TextBlock Foreground="{StaticResource TxtMuted}" FontSize="13">
                                                    <Run Text="↑ "/>
                                                    <Run Text="{Binding MonNetUpKBs, StringFormat={}{0:F0} Ko/s}"/>
                                                </TextBlock>
                                                <TextBlock Foreground="{StaticResource TxtMuted}" FontSize="12" Margin="0,2,0,0">
                                                    <Run Text="Ping: "/>
                                                    <Run Text="{Binding MonPingLabel, Mode=OneWay}" FontWeight="SemiBold" Foreground="#06B6D4"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <local:SparklineChart Grid.Row="2" Height="56"
                                                              LatestValue="{Binding MonNetDownKBs}">
                                            <local:SparklineChart.StrokeBrush>
                                                <SolidColorBrush Color="#06B6D4"/>
                                            </local:SparklineChart.StrokeBrush>
                                        </local:SparklineChart>
                                    </Grid>
                                </Border>

                                <!-- DISQUE -->
                                <Border Style="{StaticResource SmallCard}" Margin="6,0,0,0" Padding="18,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="56"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="DISQUE R/W" Style="{StaticResource MetricLabel}" Margin="0"/>
                                                <TextBlock FontSize="22" FontWeight="Black" Foreground="#F59E0B">
                                                    <Run Text="{Binding MonDiskReadMBs, StringFormat={}{0:F0}}"/>
                                                    <Run Text="/" FontSize="14" Foreground="{StaticResource TxtMuted}"/>
                                                    <Run Text="{Binding MonDiskWriteMBs, StringFormat={}{0:F0} Mo/s}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DiskSummary}" Foreground="{StaticResource TxtMuted}"
                                                       FontSize="13" VerticalAlignment="Bottom" Margin="12,0,0,6"
                                                       TextWrapping="Wrap" MaxWidth="200"/>
                                        </StackPanel>
                                        <local:SparklineChart Grid.Row="2" Height="56"
                                                              LatestValue="{Binding MonDiskReadMBs}">
                                            <local:SparklineChart.StrokeBrush>
                                                <SolidColorBrush Color="#F59E0B"/>
                                            </local:SparklineChart.StrokeBrush>
                                        </local:SparklineChart>
                                    </Grid>
                                </Border>
                            </UniformGrid>

                            <!-- SCORE PC + TEMPÉRATURES -->
                            <UniformGrid Columns="2" Margin="0,0,0,16">

                                <!-- SCORE PC -->
                                <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,16,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="#1E1232"/>
                                            </Border.Background>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PcScoreGrade}"
                                                           FontSize="28" FontWeight="Black" TextAlignment="Center"
                                                           Foreground="{Binding PcScoreBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="SCORE PC GLOBAL" Style="{StaticResource MetricLabel}" Margin="0,0,0,4"/>
                                            <TextBlock FontSize="32" FontWeight="Black">
                                                <Run Text="{Binding PcScore}"/>
                                                <Run Text="/100" FontSize="16" Foreground="{StaticResource TxtMuted}"/>
                                            </TextBlock>
                                            <TextBlock Text="Basé sur l'analyse diagnostics" FontSize="12"
                                                       Foreground="{StaticResource TxtMuted}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding PcScoreAdvice}" FontSize="12"
                                                       Foreground="{StaticResource TxtMuted}" Margin="0,6,0,0"
                                                       TextWrapping="Wrap" MaxWidth="280"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- TEMPÉRATURES -->
                                <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="TEMPÉRATURES" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="CPU" FontSize="12" Foreground="{StaticResource TxtMuted}"/>
                                                <TextBlock Text="{Binding MonCpuTempLabel}" FontSize="24" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MonCpuTempLabel}" Value="—">
                                                                    <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
                                                                    <Setter Property="FontSize" Value="18"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TxtMuted}" Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MonCpuTempLabel}" Value="—">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Text" Value="Capteur non dispo."/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="GPU" FontSize="12" Foreground="{StaticResource TxtMuted}" TextAlignment="Right"/>
                                                <TextBlock Text="{Binding MonGpuTempLabel}" FontSize="24" FontWeight="Bold"
                                                           Foreground="#F59E0B" TextAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Background="#1E1232" Height="1" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource TxtMuted}" FontSize="12">
                                                <Run Text="GPU Load: "/>
                                                <Run Text="{Binding MonGpuLoad, StringFormat={}{0:F0}%}" FontWeight="SemiBold" Foreground="{StaticResource TxtSecond}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Foreground="{StaticResource TxtMuted}" FontSize="12">
                                                <Run Text="VRAM: "/>
                                                <Run Text="{Binding MonGpuVramLabel, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TxtSecond}"/>
                                            </TextBlock>
                                        </Grid>
                                        <Border Background="#1E1232" Height="1" Margin="0,6,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource TxtMuted}" FontSize="12">
                                                <Run Text="Fan CPU: "/>
                                                <Run Text="{Binding MonCpuFanLabel, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TxtSecond}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Foreground="{StaticResource TxtMuted}" FontSize="12">
                                                <Run Text="Fan GPU: "/>
                                                <Run Text="{Binding MonGpuFanLabel, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TxtSecond}"/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- CŒURS LOGIQUES + TOP PROCESSUS -->
                            <UniformGrid Columns="2" Margin="0,0,0,0">
                                <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Margin="0,0,0,12">
                                            <Run Text="CŒURS LOGIQUES — "/>
                                            <Run Text="{Binding CoreUsages.Count, Mode=OneWay, StringFormat={}{0} THREADS}"/>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding CoreUsages}" Height="70">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="1,0" VerticalAlignment="Stretch">
                                                        <Border Background="#1E1232" CornerRadius="3"/>
                                                        <Border CornerRadius="3" VerticalAlignment="Bottom"
                                                                Height="{Binding Percent, Converter={StaticResource PctHeight}}">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="#A78BFA"/>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Foreground="{StaticResource TxtMuted}" FontSize="10"
                                                   Margin="0,8,0,0" TextAlignment="Center">
                                            <Run Text="moy. "/>
                                            <Run Text="{Binding MonCpuPercent, StringFormat={}{0:F0}%}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- TOP PROCESSUS RAM -->
                                <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <TextBlock Text="TOP PROCESSUS (RAM)" Style="{StaticResource MetricLabel}"/>
                                            <Button HorizontalAlignment="Right" Style="{StaticResource SecBtn}"
                                                    Padding="6,2" FontSize="13" Content="↻"
                                                    Command="{Binding RefreshTopProcessesCommand}"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding TopProcesses}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                                   Foreground="{StaticResource TxtSecond}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" FontSize="12"
                                                                   Foreground="{StaticResource TxtMuted}"
                                                                   VerticalAlignment="Center" Margin="10,0,0,0">
                                                            <Run Text="{Binding RamMB}"/>
                                                            <Run Text=" Mo"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- ══ HISTORIQUE DES ACTIONS ════════════════════════ -->
                            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="HISTORIQUE DES ACTIONS" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TxtMuted}" Margin="0,2,0,0">
                                                <Run Text="{Binding History.Count, Mode=OneWay}"/>
                                                <Run Text=" action(s) enregistrée(s)"/>
                                                <Run Text="  ·  "/>
                                                <Run Text="{Binding ScoreDeltaLabel}" Foreground="#22C55E"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Content="Rapport HTML"
                                                Command="{Binding ExportReportCommand}" VerticalAlignment="Top"
                                                ToolTip="Génère un rapport HTML complet sur le Bureau"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding History}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:HistoryEntry}">
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="18"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TimeLabel}" FontSize="11"
                                                               Foreground="{StaticResource TxtMuted}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="12"
                                                               VerticalAlignment="Center" TextAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Category}" FontSize="12"
                                                               Foreground="{StaticResource AccentLight}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Action}" FontSize="12"
                                                               Foreground="{StaticResource TxtSecond}" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Result}" FontSize="11"
                                                               Foreground="{StaticResource Success}" VerticalAlignment="Center"
                                                               Margin="8,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Aucune action enregistrée — les optimisations apparaîtront ici au fil du temps."
                                               Foreground="{StaticResource TxtMuted}" FontSize="12" FontStyle="Italic">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding History.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 1 — NETTOYAGE -->
                    <ScrollViewer x:Name="Tab1Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Nettoyage intelligent" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Supprime uniquement les fichiers temporaires, caches et journaux inutiles. Vos documents, photos, jeux et sauvegardes ne sont JAMAIS touchés." Style="{StaticResource PageSub}"/>
                            <Border Background="#0A1A0A" BorderBrush="#1A4A1A" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                                <TextBlock FontSize="13" Foreground="#4ADE80" TextWrapping="Wrap">
                                    <Run Text="🔒 "/>
                                    <Run FontWeight="SemiBold" Text="100% sécurisé — "/>
                                    <Run Text="Tous les fichiers supprimés sont régénérés automatiquement par Windows et vos applications. Aucune donnée personnelle n'est concernée."/>
                                </TextBlock>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="ESPACE RÉCUPÉRABLE" Style="{StaticResource MetricLabel}"/>
                                        <TextBlock FontSize="32" FontWeight="Black" Foreground="{StaticResource AccentLight}"
                                                   Text="{Binding TotalCleanableBytes, Converter={StaticResource SzConv}}"/>
                                        <TextBlock Text="{Binding CleanStatus}" Foreground="{StaticResource TxtSecond}" FontSize="12" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Style="{StaticResource SecBtn}" Command="{Binding ScanCleanCommand}"
                                                    IsEnabled="{Binding IsScanning, Converter={StaticResource InvBool}}"
                                                    Content="Analyser" Margin="0,0,8,0"/>
                                            <Button Style="{StaticResource PrimaryBtn}" Command="{Binding CleanSelectedCommand}"
                                                    IsEnabled="{Binding IsCleaning, Converter={StaticResource InvBool}}"
                                                    Content="Nettoyer"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,4,0,0">
                                            <TextBlock TextAlignment="Right" FontSize="12">
                                                <Run FontWeight="SemiBold" Foreground="{StaticResource TxtSecond}" Text="Analyser"/>
                                                <Run Foreground="{StaticResource TxtMuted}" Text=" — détecte les fichiers récupérables"/>
                                            </TextBlock>
                                            <TextBlock TextAlignment="Right" FontSize="12" Margin="0,3,0,0">
                                                <Run FontWeight="SemiBold" Foreground="{StaticResource TxtSecond}" Text="Nettoyer"/>
                                                <Run Foreground="{StaticResource TxtMuted}" Text=" — supprime les catégories cochées"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="CORBEILLE" Style="{StaticResource MetricLabel}"/>
                                        <TextBlock Text="{Binding RecycleSize, Converter={StaticResource SzConv}}"
                                                   Foreground="{StaticResource TxtPrimary}" FontSize="14" Margin="0,4,0,0"/>
                                        <TextBlock FontSize="13" Foreground="{StaticResource TxtMuted}" Margin="0,4,0,0"
                                                   Text="Supprime définitivement tous les fichiers dans votre corbeille Windows."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource SecBtn}"
                                            Command="{Binding EmptyRecycleBinCommand}"
                                            Content="Vider la corbeille" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="CATÉGORIES" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding CleanCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#12091C" CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                                  Style="{StaticResource Toggle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TxtPrimary}" FontSize="13"/>
                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TxtSecond}" FontSize="13"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding SizeLabel}"
                                                                   Foreground="{StaticResource AccentLight}" FontWeight="Bold"
                                                                   FontSize="13" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ══ CACHES JEUX ════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="CACHES JEUX" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding GameCacheStatus}" FontSize="12"
                                                       Foreground="{StaticResource TxtMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="0,0,6,0"
                                                Command="{Binding ScanGameCachesCommand}"
                                                IsEnabled="{Binding IsGameCacheBusy, Converter={StaticResource InvBool}}"
                                                VerticalAlignment="Top"
                                                ToolTip="Scanne les dossiers cache de Steam, Discord, FiveM, Valorant, Epic, Minecraft…">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Scanner"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGameCacheBusy}" Value="True">
                                                                <Setter Property="Text" Value="Scan…"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" VerticalAlignment="Top"
                                                Command="{Binding CleanAllGameCachesCommand}"
                                                IsEnabled="{Binding IsGameCacheBusy, Converter={StaticResource InvBool}}"
                                                ToolTip="Nettoie tous les caches de jeux détectés en une fois">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Tout nettoyer"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGameCacheBusy}" Value="True">
                                                                <Setter Property="Text" Value="Nettoyage…"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding GameCaches}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:GameCache}">
                                                <Border Background="#12091C" CornerRadius="8" Padding="12,8" Margin="0,0,0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Game}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TxtPrimary}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding SizeLabel}" FontSize="13" FontWeight="Bold"
                                                                   TextAlignment="Right" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Button Grid.Column="3" Style="{StaticResource SecBtn}" Margin="8,0,0,0"
                                                                Padding="10,4" FontSize="12" Content="Nettoyer"
                                                                IsEnabled="{Binding IsEmpty, Converter={StaticResource InvBool}}"
                                                                ToolTip="Supprime les fichiers cache de ce jeu pour libérer de l'espace"
                                                                Command="{Binding DataContext.CleanGameCacheCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Cliquez sur 'Scanner' pour détecter les caches de vos jeux installés."
                                               Foreground="{StaticResource TxtMuted}" FontSize="12" FontStyle="Italic" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GameCaches.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>


                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 2 — DÉMARRAGE -->
                    <ScrollViewer x:Name="Tab2Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Gestion du démarrage" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Programmes qui se lancent automatiquement avec Windows. Désactiver un programme n'est pas le supprimer — il reste installé et fonctionnel, il ne se lance juste plus au démarrage." Style="{StaticResource PageSub}"/>
                            <TextBlock Text="{Binding StartupStatus}" Foreground="{StaticResource TxtMuted}" FontSize="13" Margin="0,-10,0,14"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="PROGRAMMES AU DÉMARRAGE" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Startup}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Margin="0,0,0,6" ClipToBounds="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#100B1E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                    <Setter Property="Background" Value="#180808"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <!-- Barre accent gauche (verte=actif, rouge=désactivé) -->
                                                        <Border Width="4" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#22C55E"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                            <Setter Property="Background" Value="#7F1D1D"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>

                                                        <!-- Contenu -->
                                                        <Grid Margin="18,12,14,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="90"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Nom + exe -->
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="14" FontWeight="Bold"
                                                                           Foreground="{StaticResource TxtPrimary}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock FontSize="11" Margin="0,2,0,0"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                                    <Setter Property="Foreground" Value="#B06060"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                    <Run Text="{Binding ExeName, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                    <Run Text="{Binding Source, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- Bouton toggle -->
                                                            <Button Grid.Column="2"
                                                                    Command="{Binding DataContext.ToggleStartupEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Cursor="Hand" VerticalAlignment="Center"
                                                                    HorizontalAlignment="Right"
                                                                    BorderThickness="0" Padding="0,6" Width="84">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="#14532D"/>
                                                                        <Setter Property="Foreground" Value="#4ADE80"/>
                                                                        <Setter Property="FontSize"   Value="12"/>
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border Background="{TemplateBinding Background}"
                                                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                          TextOptions.TextRenderingMode="ClearType"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Opacity" Value="0.85"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                                <Setter Property="Background" Value="#450A0A"/>
                                                                                <Setter Property="Foreground" Value="#FCA5A5"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <TextBlock TextOptions.TextRenderingMode="ClearType">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="✓  Actif"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                                    <Setter Property="Text" Value="✕  Désactivé"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Button>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 3 — RÉSEAU -->
                    <ScrollViewer x:Name="Tab3Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Optimisation réseau" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="DNS, TCP/IP, latence et adaptateurs réseau." Style="{StaticResource PageSub}"/>

                            <!-- ══ TEST DE VITESSE INTERNET (supprimé) ══ -->
                            <Border Margin="0,0,0,16" CornerRadius="14" Padding="20,18" Visibility="Collapsed">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#110A2E" Offset="0"/>
                                        <GradientStop Color="#0D0A1A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4C1D95" Offset="0"/>
                                        <GradientStop Color="#1E3A5F" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel>

                                    <!-- En-tête -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="TEST DE VITESSE INTERNET" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding SpeedTestStatus}" Foreground="{StaticResource TxtMuted}"
                                                       FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Width="180" Height="54"
                                                Command="{Binding RunSpeedTestCommand}"
                                                IsEnabled="{Binding IsSpeedTesting, Converter={StaticResource InvBool}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="10" Padding="16,10" Cursor="Hand">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#7C3AED" Offset="0"/>
                                                                <GradientStop Color="#2563EB" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="⚡  Lancer le test"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSpeedTesting}" Value="True">
                                                                                <Setter Property="Text" Value="⏳  Test en cours…"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="via Cloudflare CDN" FontSize="10"
                                                                       Foreground="#C4B5FD" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Jauge live (visible pendant le test et après) -->
                                    <local:CircularGauge Value="{Binding SpeedGaugeValue}"
                                                         Title="VITESSE INTERNET"
                                                         CenterText="{Binding SpeedLiveLabel}"
                                                         Subtitle="{Binding SpeedPhase}"
                                                         Width="220" Height="220"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,0,0,16"
                                                         Visibility="{Binding SpeedGaugeVisible, Converter={StaticResource BoolToVis}}">
                                        <local:CircularGauge.ArcBrush>
                                            <SolidColorBrush Color="#7C3AED"/>
                                        </local:CircularGauge.ArcBrush>
                                    </local:CircularGauge>

                                    <!-- 4 cartes de résultats (après test) -->
                                    <Grid Margin="0,0,0,12"
                                          Visibility="{Binding SpeedTestDone, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="#0D0B1A" CornerRadius="10" Padding="12,12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="↓" FontSize="18" HorizontalAlignment="Center" Foreground="#7C3AED"/>
                                                <TextBlock Text="{Binding SpeedDownLabel}" FontSize="20" FontWeight="Black"
                                                           Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                                <TextBlock Text="TÉLÉCH." FontSize="9" Foreground="{StaticResource TxtMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="#0D0B1A" CornerRadius="10" Padding="12,12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="↑" FontSize="18" HorizontalAlignment="Center" Foreground="#06B6D4"/>
                                                <TextBlock Text="{Binding SpeedUpLabel}" FontSize="20" FontWeight="Black"
                                                           Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                                <TextBlock Text="UPLOAD" FontSize="9" Foreground="{StaticResource TxtMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Background="#0D0B1A" CornerRadius="10" Padding="12,12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="◎" FontSize="18" HorizontalAlignment="Center" Foreground="#22C55E"/>
                                                <TextBlock Text="{Binding SpeedPingLabel}" FontSize="20" FontWeight="Black"
                                                           Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                                <TextBlock Text="LATENCE" FontSize="9" Foreground="{StaticResource TxtMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="6" Background="#0D0B1A" CornerRadius="10" Padding="12,12">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="≈" FontSize="18" HorizontalAlignment="Center" Foreground="#F59E0B"/>
                                                <TextBlock Text="{Binding SpeedJitterLabel}" FontSize="20" FontWeight="Black"
                                                           Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                                <TextBlock Text="JITTER" FontSize="9" Foreground="{StaticResource TxtMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Badge connexion + conseil -->
                                    <Border CornerRadius="8" Padding="14,10" Background="#0B1A0B"
                                            Visibility="{Binding SpeedTestDone, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#142814" CornerRadius="6" Padding="10,6"
                                                    Margin="0,0,14,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SpeedConnectionType}" Foreground="#22C55E"
                                                           FontWeight="Bold" FontSize="12"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SpeedGrade}" Foreground="#22C55E"
                                                           FontWeight="Bold" FontSize="13" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding SpeedAdvice}" Foreground="{StaticResource TxtMuted}"
                                                           FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </Border>

                            <!-- ══ TEST DE LATENCE ═══════════════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="TEST DE LATENCE" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#12091C" CornerRadius="8" Padding="14,10">
                                            <TextBlock Text="{Binding PingResult}" Foreground="{StaticResource Success}"
                                                       FontFamily="Consolas" FontSize="12"/>
                                        </Border>
                                        <Button Grid.Column="1" Style="{StaticResource PrimaryBtn}"
                                                Command="{Binding PingTestCommand}"
                                                IsEnabled="{Binding IsNetBusy, Converter={StaticResource InvBool}}"
                                                Content="Tester le ping" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="OPTIMISATIONS" Style="{StaticResource MetricLabel}" Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Optimiser TCP/IP" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TxtPrimary}"/>
                                            <TextBlock FontSize="13" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"
                                                       Text="Ajuste les paramètres TCP/IP de Windows pour réduire la latence et améliorer le débit réseau."/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="12,0,0,0"
                                                Command="{Binding OptimizeTcpCommand}"
                                                IsEnabled="{Binding IsNetBusy, Converter={StaticResource InvBool}}"
                                                Content="Appliquer" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border Background="#0D0818" Height="1" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Vider le cache DNS" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TxtPrimary}"/>
                                            <TextBlock FontSize="13" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"
                                                       Text="Efface les adresses de sites mémorisées par Windows. Utile si certains sites ne chargent pas correctement."/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="12,0,0,0"
                                                Command="{Binding FlushDnsCommand}"
                                                IsEnabled="{Binding IsNetBusy, Converter={StaticResource InvBool}}"
                                                Content="Vider" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border Background="#0D0818" Height="1" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="DNS Cloudflare 1.1.1.1" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TxtPrimary}"/>
                                            <TextBlock FontSize="13" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"
                                                       Text="Configure votre carte réseau pour utiliser le DNS le plus rapide au monde (Cloudflare). Réduit le temps de chargement des sites."/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="12,0,0,0"
                                                Command="{Binding OptimizeDnsServersCommand}"
                                                IsEnabled="{Binding IsNetBusy, Converter={StaticResource InvBool}}"
                                                Content="Appliquer" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border Background="#0D0818" Height="1" Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Paramètres réseau Windows" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TxtPrimary}"/>
                                            <TextBlock FontSize="13" Foreground="{StaticResource TxtMuted}"
                                                       Text="Ouvre les paramètres réseau de Windows pour configurer vos connexions manuellement."/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="12,0,0,0"
                                                Content="Ouvrir" VerticalAlignment="Center"
                                                Click="OpenNetworkSettings_Click"/>
                                    </Grid>

                                    <!-- RÉSULTAT visible en bas après chaque action -->
                                    <Border Background="#0D1A0D" CornerRadius="8" Padding="14,10" Margin="0,14,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⏳"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNetBusy}" Value="False">
                                                                <Setter Property="Text" Value="✓"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding NetOptStatus}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Success}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- DNS SPEED TEST -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="DNS SPEED TEST" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding DnsTestStatus}" FontSize="12"
                                                       Foreground="{StaticResource TxtMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="0,0,6,0"
                                                VerticalAlignment="Top"
                                                Command="{Binding TestAllDnsCommand}"
                                                IsEnabled="{Binding IsDnsBusy, Converter={StaticResource InvBool}}"
                                                ToolTip="Teste la latence de 8 serveurs DNS depuis votre connexion et les classe du plus rapide au plus lent">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Tester les DNS"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDnsBusy}" Value="True">
                                                                <Setter Property="Text" Value="Test en cours…"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource SecBtn}"
                                                Command="{Binding ResetDnsToAutoCommand}"
                                                IsEnabled="{Binding IsDnsBusy, Converter={StaticResource InvBool}}"
                                                VerticalAlignment="Top"
                                                ToolTip="Remet les DNS en automatique (DHCP) — DNS attribué par votre box">
                                            <TextBlock Text="Remettre en auto"/>
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding DnsResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:DnsResult}">
                                                <Border CornerRadius="8" Padding="12,8" Margin="0,0,0,5">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#12091C"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Available}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.45"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Server.Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TxtPrimary}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Server.Description}" FontSize="11"
                                                                   Foreground="{StaticResource TxtMuted}" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding PingLabel}" FontSize="13" FontWeight="Bold"
                                                                   TextAlignment="Right" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Available}" Value="False">
                                                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Border Grid.Column="3" Background="#1A1028" CornerRadius="4" Padding="6,2"
                                                                Margin="8,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Grade}" FontSize="11" FontWeight="Bold"
                                                                       Foreground="{StaticResource AccentLight}"/>
                                                        </Border>
                                                        <Button Grid.Column="4" Style="{StaticResource PrimaryBtn}"
                                                                Padding="10,4" FontSize="12" Content="Appliquer"
                                                                IsEnabled="{Binding Available}"
                                                                ToolTip="Applique ce serveur DNS sur tous vos adaptateurs réseau actifs"
                                                                Command="{Binding DataContext.ApplyDnsServerCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Cliquez sur 'Tester les DNS' pour mesurer la latence de chaque serveur depuis votre connexion."
                                               Foreground="{StaticResource TxtMuted}" FontSize="12" FontStyle="Italic">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DnsResults.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 4 — STOCKAGE -->
                    <ScrollViewer x:Name="Tab4Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Gestion du stockage" Style="{StaticResource PageTitle}"/>
                            <!-- Barre de statut principale — toujours visible -->
                            <Border Background="#120D1F" CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                                    BorderBrush="#2D1F45" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="●"/>
                                                <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStorageBusy}" Value="True">
                                                        <Setter Property="Text"       Value="◌"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding StorageStatus}" Foreground="{StaticResource TxtSecond}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- ══ PARTITIONS ══════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="PARTITIONS" Style="{StaticResource MetricLabel}" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding Partitions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:PartitionInfo}">
                                                <StackPanel Margin="0,0,0,14">
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                            <Border Background="#2D1B4E" CornerRadius="5" Padding="8,3" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding Letter}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="{StaticResource AccentLight}"/>
                                                            </Border>
                                                            <Border CornerRadius="4" Padding="6,3">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#1A2E1A"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSSD}" Value="False">
                                                                                <Setter Property="Background" Value="#1A0F2E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding TypeLabel}" FontSize="10" FontWeight="Bold"
                                                                           Foreground="{StaticResource TxtMuted}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding UsedLabel}" FontSize="12"
                                                                   Foreground="{StaticResource TxtSecond}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding PctLabel}" FontSize="13" FontWeight="Bold"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UsedPct, Converter={StaticResource BoolText}, ConverterParameter='high|low'}" Value="high">
                                                                            <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                    <!-- ProgressBar — beaucoup plus simple et fiable que MultiBinding -->
                                                    <ProgressBar Value="{Binding UsedPct, Mode=OneWay}" Minimum="0" Maximum="100"
                                                                 Height="7" Background="#1A1028">
                                                        <ProgressBar.Style>
                                                            <Style TargetType="ProgressBar">
                                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsedPct, Converter={StaticResource BoolText}, ConverterParameter='high|low'}" Value="high">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ProgressBar.Style>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Aucune partition détectée — les partitions se chargent au premier accès à cet onglet."
                                               Foreground="{StaticResource TxtMuted}" FontSize="12" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Partitions.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- ══ TRIM + BENCHMARK ═══════════════════════════════ -->
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <!-- TRIM -->
                                <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="TRIM SSD" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Row="1" FontSize="12" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Text="Nettoie les blocs inutilisés du SSD pour maintenir les vitesses maximales dans le temps. Recommandé 1× par mois."/>
                                        <Button Grid.Row="2" Style="{StaticResource PrimaryBtn}" Command="{Binding RunTrimCommand}" Height="40"
                                                IsEnabled="{Binding IsStorageBusy, Converter={StaticResource InvBool}}">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Exécuter TRIM"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsStorageBusy}" Value="True">
                                                                    <Setter Property="Text" Value="En cours…"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </Border>
                                <!-- Benchmark -->
                                <Border Style="{StaticResource Card}" Margin="6,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="BENCHMARK DISQUE" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                                        <StackPanel Grid.Row="1">
                                        <TextBlock FontSize="12" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap" Margin="0,0,0,6"
                                                   Text="Mesure la vitesse réelle de lecture et d'écriture du disque système. Permet de vérifier les performances de votre SSD ou HDD."/>
                                        <TextBlock Text="{Binding BenchmarkResult}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBenchmarking}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Row="2" Style="{StaticResource PrimaryBtn}" Command="{Binding RunBenchmarkCommand}" Height="40"
                                                IsEnabled="{Binding IsBenchmarking, Converter={StaticResource InvBool}}">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Lancer le benchmark"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBenchmarking}" Value="True">
                                                                    <Setter Property="Text" Value="Benchmark en cours…"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </Border>
                            </UniformGrid>

                            <!-- ══ GROS FICHIERS ═══════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="GROS FICHIERS" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding BigFilesStatus}" FontSize="12" Foreground="{StaticResource TxtMuted}"
                                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" VerticalAlignment="Top"
                                                Command="{Binding ScanLargeFilesCommand}"
                                                IsEnabled="{Binding IsScanningFiles, Converter={StaticResource InvBool}}">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Scanner (50 Mo+)"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsScanningFiles}" Value="True">
                                                                    <Setter Property="Text" Value="Scan en cours…"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding BigFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:BigFileEntry}">
                                                <Border Background="#12091C" CornerRadius="6" Padding="10,7" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TxtPrimary}"/>
                                                            <TextBlock Text="{Binding Folder}" FontSize="10"
                                                                       Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="#2D1B4E" CornerRadius="4" Padding="8,3" Margin="8,0">
                                                            <TextBlock Text="{Binding SizeLabel}" FontSize="12" FontWeight="Bold"
                                                                       Foreground="{StaticResource AccentLight}" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Button Grid.Column="2" Style="{StaticResource SecBtn}" Padding="10,4" FontSize="12"
                                                                Content="Ouvrir" Command="{Binding DataContext.OpenBigFileCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ══ TAILLE DES DOSSIERS ═════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="DOSSIERS PRINCIPAUX (C:\)" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding FolderSizeStatus}" FontSize="12" Foreground="{StaticResource TxtMuted}"
                                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" VerticalAlignment="Top"
                                                Command="{Binding ScanFolderSizesCommand}">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Calculer les tailles"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsScanningFiles}" Value="True">
                                                                    <Setter Property="Text" Value="Calcul…"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding FolderSizes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:FolderSizeEntry}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TxtPrimary}" VerticalAlignment="Center"/>
                                                    <!-- ProgressBar avec Pct calculé dans le ViewModel -->
                                                    <ProgressBar Grid.Column="1" Value="{Binding Pct, Mode=OneWay}"
                                                                 Minimum="0" Maximum="100" Height="7" Margin="8,0"
                                                                 Background="#1A1028" Foreground="#7C3AED"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding SizeLabel}" FontSize="12"
                                                               Foreground="{StaticResource AccentLight}" TextAlignment="Right"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Cliquez sur 'Calculer les tailles' pour voir quels dossiers occupent le plus d'espace."
                                               Foreground="{StaticResource TxtMuted}" FontSize="11" FontStyle="Italic"
                                               TextWrapping="Wrap" Margin="0,6,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FolderSizes.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- ══ DISQUES PHYSIQUES ═══════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="DISQUES PHYSIQUES" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Drives}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:DriveHealth}">
                                                <Border Background="#12091C" CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <Border Background="#2D1B4E" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                                    <TextBlock Text="{Binding MediaType}" FontSize="10" FontWeight="Bold"
                                                                               Foreground="{StaticResource AccentLight}"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Model}" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TxtPrimary}" FontSize="13"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}">
                                                                <Run Text="{Binding SizeGB, Mode=OneWay}"/><Run Text=" Go  ·  Lecture ~"/>
                                                                <Run Text="{Binding ReadSpeedMBs, Mode=OneWay}"/><Run Text=" Mo/s"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                                                            <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold"
                                                                       Foreground="{StaticResource Success}" TextAlignment="Right"/>
                                                            <TextBlock FontSize="20" FontWeight="Black"
                                                                       Foreground="{StaticResource AccentLight}" TextAlignment="Right">
                                                                <Run Text="{Binding HealthPercent, Mode=OneWay}"/><Run Text="%"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 5 — PILOTES -->
                    <ScrollViewer x:Name="Tab5Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Gestion des pilotes" Style="{StaticResource PageTitle}"/>
                                    <TextBlock Style="{StaticResource PageSub}"
                                               Text="Liste tous les pilotes installés sur votre PC. Un ⚠ indique un pilote potentiellement obsolète ou non signé à vérifier."/>
                                    <TextBlock Text="{Binding DriverStatus}" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource SecBtn}" Command="{Binding ToggleShowAllDriversCommand}"
                                            Content="{Binding ShowAllDrivers, Converter={StaticResource BoolText}, ConverterParameter='Essentiels|Tous les pilotes'}"
                                            Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource SecBtn}" Command="{Binding OpenDeviceManagerCommand}"
                                            Content="Gestionnaire de périph."/>
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12" Background="#0D0818">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💡" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"
                                               Text="Pour mettre à jour un pilote : ouvrez le Gestionnaire de périphériques → clic droit sur le composant → Mettre à jour le pilote. Pour les GPU, téléchargez directement depuis NVIDIA.com ou AMD.com."/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <DataGrid ItemsSource="{Binding Drivers}" AutoGenerateColumns="False" MaxHeight="580">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="État" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" FontSize="14" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text"       Value="✓"/>
                                                                <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                                                        <Setter Property="Text"       Value="⚠"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Périphérique"  Binding="{Binding DeviceName}"    Width="*"/>
                                        <DataGridTextColumn Header="Classe"         Binding="{Binding DeviceClass}"   Width="150"/>
                                        <DataGridTextColumn Header="Fabricant"      Binding="{Binding Manufacturer}"  Width="130"/>
                                        <DataGridTextColumn Header="Version"        Binding="{Binding DriverVersion}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 6 — PROBLÈMES -->
                    <ScrollViewer x:Name="Tab6Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Détection de problèmes" Style="{StaticResource PageTitle}"/>
                                    <TextBlock Text="{Binding DiagStatus}" Style="{StaticResource PageSub}" Margin="0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding RefreshDiagnosticsCommand}"
                                        IsEnabled="{Binding IsDiagBusy, Converter={StaticResource InvBool}}"
                                        Content="Analyser" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#3D1515" CornerRadius="8" Padding="14,8" Margin="0,0,10,0">
                                    <TextBlock Foreground="{StaticResource Danger}" FontWeight="Bold" FontSize="13">
                                        <Run Text="{Binding CriticalCount}"/><Run Text=" critique(s)"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#2D2010" CornerRadius="8" Padding="14,8">
                                    <TextBlock Foreground="{StaticResource Warning}" FontWeight="Bold" FontSize="13">
                                        <Run Text="{Binding WarningCount}"/><Run Text=" avertissement(s)"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Issues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type svc:DiagnosticIssue}">
                                        <Border CornerRadius="10" Padding="16,12" Margin="0,0,0,8" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"  Value="#1A1028"/>
                                                    <Setter Property="BorderBrush" Value="#2D1F45"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                            <Setter Property="Background"  Value="#1F0A0A"/>
                                                            <Setter Property="BorderBrush" Value="#5A1A1A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                            <Setter Property="Background"  Value="#1A150A"/>
                                                            <Setter Property="BorderBrush" Value="#4A3A10"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="20" Margin="0,0,14,0" VerticalAlignment="Top">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text"       Value="✓"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Text"       Value="✕"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                    <Setter Property="Text"       Value="△"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TxtPrimary}" FontSize="13"/>
                                                        <Border Background="#2D1B4E" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource AccentLight}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TxtSecond}"
                                                               FontSize="12" Margin="0,4,0,4" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="13" FontStyle="Italic" TextWrapping="Wrap">
                                                        <Run Text="→ " Foreground="{StaticResource AccentLight}"/>
                                                        <Run Text="{Binding Recommendation}" Foreground="{StaticResource TxtSecond}"/>
                                                    </TextBlock>
                                                    <Button Margin="0,10,0,0" HorizontalAlignment="Left"
                                                            Style="{StaticResource PrimaryBtn}"
                                                            Visibility="{Binding HasFix, Converter={StaticResource BoolToVis}}"
                                                            Content="{Binding FixLabel}"
                                                            Command="{Binding DataContext.FixIssueCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 7 — PROFILS -->
                    <ScrollViewer x:Name="Tab7Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Profils d'optimisation" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Appliquez un profil complet en un clic. Sauvegardez d'abord votre état actuel pour pouvoir y revenir exactement à tout moment." Style="{StaticResource PageSub}"/>

                            <!-- Sauvegarde / Restauration -->
                            <Border Style="{StaticResource Card}" Background="#0C0A18" BorderBrush="#352055" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="VOTRE CONFIGURATION ACTUELLE" Style="{StaticResource MetricLabel}"/>
                                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource TxtPrimary}" Margin="0,4,0,4">
                                            <Run Text="Sauvegardez avant d'appliquer un profil"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"
                                                   Text="Capture l'état exact de tous vos tweaks (Gaming + Confidentialité). Restaurez en un clic pour revenir exactement où vous étiez."/>
                                        <TextBlock Text="{Binding SnapshotLabel}" FontSize="12" FontStyle="Italic"
                                                   Foreground="{StaticResource Success}" Margin="0,6,0,0"
                                                   Visibility="{Binding HasSnapshot, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <Button Style="{StaticResource PrimaryBtn}" Margin="0,0,0,6"
                                                Command="{Binding SaveCurrentStateCommand}"
                                                Content="💾  Sauvegarder mon état"/>
                                        <Button Style="{StaticResource SecBtn}" Margin="0,0,0,6"
                                                Command="{Binding RestoreSnapshotCommand}"
                                                Content="↩  Restaurer ma config"
                                                Visibility="{Binding HasSnapshot, Converter={StaticResource BoolToVis}}"/>
                                        <Button Padding="12,6" Margin="0,0,0,0"
                                                Command="{Binding ClearSnapshotCommand}"
                                                Visibility="{Binding HasSnapshot, Converter={StaticResource BoolToVis}}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background"   Value="Transparent"/>
                                                    <Setter Property="Foreground"   Value="#6B2020"/>
                                                    <Setter Property="FontSize"     Value="11"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush"  Value="#3D1010"/>
                                                    <Setter Property="Cursor"       Value="Hand"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                      TextOptions.TextRenderingMode="ClearType"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background"  Value="#2A0A0A"/>
                                                                        <Setter Property="Foreground"  Value="#FCA5A5"/>
                                                                        <Setter Property="BorderBrush" Value="#7F1D1D"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="✕  Supprimer la sauvegarde"
                                                       TextOptions.TextRenderingMode="ClearType"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Statut du dernier profil appliqué -->
                            <Border Style="{StaticResource Card}" Background="#0D1A0D" Margin="0,0,0,16">
                                <TextBlock Text="{Binding ProfileStatus}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Success}" TextWrapping="Wrap"/>
                            </Border>
                            <UniformGrid Columns="2">
                                <!-- GAMING -->
                                <Border Margin="0,0,8,8" Padding="20,18">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                            <Setter Property="CornerRadius"    Value="10"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGamingProfileActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                                    <Setter Property="Background"  Value="#0A1A0D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="GAMING" Style="{StaticResource MetricLabel}" Margin="0"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                    Visibility="{Binding IsGamingProfileActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Profil Gaming" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,8"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"
                                                   Text="Game DVR off, fullscreen optimisé, GPU priority, réactivité max, Win32 priority, souris précise, haute perf, réseau sans limite."/>
                                        <Button HorizontalAlignment="Left" Command="{Binding ApplyGamingProfileCommand}"
                                                Content="{Binding IsGamingProfileActive, Converter={StaticResource BoolText}, ConverterParameter='✓ Gaming actif|Appliquer Gaming'}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGamingProfileActive}" Value="True">
                                                            <Setter Property="Background"  Value="#0D2E14"/>
                                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                                            <Setter Property="Foreground"  Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <!-- BUREAUTIQUE -->
                                <Border Margin="8,0,0,8" Padding="20,18">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                            <Setter Property="CornerRadius"    Value="10"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBureauProfileActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                                    <Setter Property="Background"  Value="#0A1A0D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="BUREAUTIQUE" Style="{StaticResource MetricLabel}" Margin="0"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                    Visibility="{Binding IsBureauProfileActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Profil Bureau" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,8"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"
                                                   Text="Télémétrie off, ID publicitaire off, effets visuels minimalistes, plan équilibré."/>
                                        <Button HorizontalAlignment="Left" Command="{Binding ApplyBureautiqueProfileCommand}"
                                                Content="{Binding IsBureauProfileActive, Converter={StaticResource BoolText}, ConverterParameter='✓ Bureau actif|Appliquer Bureau'}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBureauProfileActive}" Value="True">
                                                            <Setter Property="Background"  Value="#0D2E14"/>
                                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                                            <Setter Property="Foreground"  Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <!-- MULTITÂCHE -->
                                <Border Margin="0,0,8,0" Padding="20,18">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                            <Setter Property="CornerRadius"    Value="10"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMultitacheProfileActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                                    <Setter Property="Background"  Value="#0A1A0D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="MULTITÂCHE" Style="{StaticResource MetricLabel}" Margin="0"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                    Visibility="{Binding IsMultitacheProfileActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Profil Multitâche" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,8"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"
                                                   Text="Réactivité max, réseau sans throttling, plan haute performance."/>
                                        <Button HorizontalAlignment="Left" Command="{Binding ApplyMultitacheProfileCommand}"
                                                Content="{Binding IsMultitacheProfileActive, Converter={StaticResource BoolText}, ConverterParameter='✓ Multitâche actif|Appliquer Multitâche'}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMultitacheProfileActive}" Value="True">
                                                            <Setter Property="Background"  Value="#0D2E14"/>
                                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                                            <Setter Property="Foreground"  Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <!-- VIE PRIVÉE -->
                                <Border Margin="8,0,0,0" Padding="20,18">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                            <Setter Property="CornerRadius"    Value="10"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPrivacyProfileActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                                    <Setter Property="Background"  Value="#0A1A0D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="VIE PRIVÉE" Style="{StaticResource MetricLabel}" Margin="0"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                    Visibility="{Binding IsPrivacyProfileActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Profil Confidentialité" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,8"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"
                                                   Text="Télémétrie off, ID publicitaire off, localisation off, Cortana off."/>
                                        <Button HorizontalAlignment="Left" Command="{Binding ApplyPrivacyProfileCommand}"
                                                Content="{Binding IsPrivacyProfileActive, Converter={StaticResource BoolText}, ConverterParameter='✓ Confidentialité actif|Appliquer Confidentialité'}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPrivacyProfileActive}" Value="True">
                                                            <Setter Property="Background"  Value="#0D2E14"/>
                                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                                            <Setter Property="Foreground"  Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <!-- Réinitialisation Windows Défaut -->
                            <Border Style="{StaticResource Card}" Background="#100D1A" Margin="0,12,0,0" BorderThickness="1" BorderBrush="#3A2A5E">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RÉINITIALISATION" Style="{StaticResource MetricLabel}"/>
                                        <TextBlock Text="Restaurer les paramètres Windows d'origine" FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,4,0,6"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TxtSecond}"
                                                   Text="Désactive tous les tweaks appliqués — votre PC revient exactement à son état Windows d'origine. Rien n'est supprimé, aucun fichier touché."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource SecBtn}" VerticalAlignment="Center" Margin="20,0,0,0"
                                            Command="{Binding ApplyWindowsDefaultProfileCommand}"
                                            Content="↩ Restaurer défaut Windows"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 8 — GAMING -->
                    <ScrollViewer x:Name="Tab8Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Optimisation Gaming" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Tweaks Windows pour maximiser les FPS et réduire la latence. Tous réversibles en un clic — aucun fichier de jeu modifié." Style="{StaticResource PageSub}"/>

                            <!-- ══ MODE TURBO ════════════════════════════════════════ -->
                            <Border Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"    Value="#1A1028"/>
                                        <Setter Property="CornerRadius"  Value="14"/>
                                        <Setter Property="Padding"       Value="22,18"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush"   Value="#3D2860"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTurboActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#7C3AED"/>
                                                <Setter Property="Background"  Value="#1C0F38"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="⚡ MODE TURBO" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentLight}"/>
                                            <Border Background="#7C3AED" CornerRadius="4" Padding="7,2" Margin="10,0,0,0"
                                                    Visibility="{Binding IsTurboActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="ACTIF" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,4" TextWrapping="Wrap">
                                            <Run Text="Plan Ultimate Performance + services gaming optimisés + Game Booster ON — performances maximales en un clic."/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TurboSummary}" FontSize="12"
                                                   Foreground="{StaticResource AccentLight}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" VerticalAlignment="Center" MinWidth="160" Height="42"
                                            Margin="16,0,0,0" Command="{Binding ToggleTurboCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                                <Setter Property="Content" Value="⚡ Activer Turbo"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTurboActive}" Value="True">
                                                        <Setter Property="Content"     Value="Désactiver Turbo"/>
                                                        <Setter Property="Background"  Value="#6C2BD9"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Disclaimer Gaming -->
                            <Border Background="#0D0A1A" BorderBrush="#2D1B4E" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ" FontSize="16" Foreground="#A78BFA"
                                               VerticalAlignment="Top" Margin="0,1,12,0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}">Information — </Run>
                                        <Run>Les optimisations gaming agissent sur les conditions réelles d'exécution de vos jeux (priorité CPU, timer système, overlays parasites, DVR Xbox). Elles ne peuvent pas garantir un nombre précis de FPS supplémentaires : les résultats dépendent de votre matériel et de votre configuration. Sur les PC peu optimisés, les gains sont généralement plus visibles.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- ══ GAME BOOSTER ══════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="GAME BOOSTER" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>

                                    <!-- Ce que fait le boost -->
                                    <Border Background="#0C0819" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="Ce que fait le boost quand tu lances un jeu :"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentLight}" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,5" TextWrapping="Wrap">
                                                        <Run Text="⚡ " Foreground="#A78BFA"/><Run Text="Priorité processus → HAUTE" FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="   Le jeu reçoit plus de temps CPU que tout le reste." FontSize="11" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,5" TextWrapping="Wrap">
                                                        <Run Text="🖥️ " Foreground="#A78BFA"/><Run Text="Tous les cores CPU dédiés" FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="   Affinité forcée sur 100% des threads disponibles." FontSize="11" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,5" TextWrapping="Wrap">
                                                        <Run Text="⏱️ " Foreground="#A78BFA"/><Run Text="Timer système → 1ms" FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="   Réduit la latence input. Windows tourne à 15ms par défaut." FontSize="11" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,5" TextWrapping="Wrap">
                                                        <Run Text="🎯 " Foreground="#A78BFA"/><Run Text="GPU Priority 8 + Win32 Priority 38" FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="   Registre Windows optimisé pour les jeux." FontSize="11" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,5" TextWrapping="Wrap">
                                                        <Run Text="🎮 " Foreground="#A78BFA"/><Run Text="DVR Xbox désactivé" FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="   Stoppe l'enregistrement en arrière-plan qui vole des ressources." FontSize="11" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,5" TextWrapping="Wrap">
                                                        <Run Text="🔍 " Foreground="#A78BFA"/><Run Text="Détection automatique" FontWeight="SemiBold" Foreground="{StaticResource TxtPrimary}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="   Surveille toutes les 3s. Se déclenche dès qu'un jeu est lancé." FontSize="11" Foreground="{StaticResource TxtMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Separator Background="#2A1A3E" Margin="0,0,0,14"/>

                                    <!-- RAM Optimizer -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Optimiseur RAM" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TxtPrimary}"/>
                                            <TextBlock Text="Libère la mémoire standby et compresse les working sets de tous les processus."
                                                       Foreground="{StaticResource TxtMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding RamBoostStatus}" FontSize="12"
                                                       Foreground="{StaticResource AccentLight}" Margin="0,5,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RamBoostStatus}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" VerticalAlignment="Center" Width="130" Height="36"
                                                Style="{StaticResource PrimaryBtn}"
                                                Command="{Binding OptimizeRamCommand}"
                                                IsEnabled="{Binding IsRamBusy, Converter={StaticResource InvBool}}">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Libérer la RAM"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRamBusy}" Value="True">
                                                                    <Setter Property="Text" Value="En cours…"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                        </Button>
                                    </Grid>

                                    <Separator Background="#2A1A3E" Margin="0,0,0,14"/>

                                    <!-- Overlay Killer -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Killer d'Overlays" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TxtPrimary}"/>
                                            <TextBlock Text="Détecte et ferme Discord Overlay, Xbox GameBar, NVIDIA Overlay et autres processus parasites."
                                                       Foreground="{StaticResource TxtMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding OverlayStatus}" FontSize="12"
                                                       Foreground="{StaticResource AccentLight}" Margin="0,5,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OverlayStatus}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding RunningOverlays}" Margin="0,6,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#2D1B4E" CornerRadius="4" Padding="7,3" Margin="0,0,5,5">
                                                            <TextBlock Text="{Binding}" FontSize="13"
                                                                       Foreground="{StaticResource AccentLight}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Button Style="{StaticResource PrimaryBtn}" MinWidth="150" Padding="16,8" Content="Scanner" Margin="0,0,0,6"
                                                    TextOptions.TextRenderingMode="ClearType"
                                                    Command="{Binding ScanOverlaysCommand}"/>
                                            <Button MinWidth="150" Cursor="Hand" BorderThickness="0"
                                                    Command="{Binding KillOverlaysCommand}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid Height="36" MinWidth="150">
                                                            <Rectangle x:Name="Bg" Fill="#7C3AED" RadiusX="8" RadiusY="8"/>
                                                            <TextBlock Text="Fermer les overlays"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="White"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="13"
                                                                       TextOptions.TextRenderingMode="ClearType"
                                                                       TextOptions.TextFormattingMode="Display"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Fill" Value="#6D28D9"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="Bg" Property="Fill" Value="#3D2A5E"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ══ TWEAKS GAMING ════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="TWEAKS GAMING" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,12" TextWrapping="Wrap"
                                               Text="Chaque tweak modifie un paramètre Windows dans le registre. Réversible à tout moment en recliquant. Aucun jeu, sauvegarde ou fichier personnel n'est modifié."/>
                                    <local:TweakRow Title="Désactiver Game DVR" Sub="Désactive l'enregistrement Xbox Game Bar en arrière-plan"
                                                    IsChecked="{Binding TwGameDvr}" Command="{Binding ToggleGameDvrCommand}"/>
                                    <local:TweakRow Title="Optimisations plein écran" Sub="Force le mode exclusif plein écran pour latence réduite"
                                                    IsChecked="{Binding TwFullscreenOptim}" Command="{Binding ToggleFullscreenOptimCommand}"/>
                                    <local:TweakRow Title="Priorité GPU/CPU élevée" Sub="GPU Priority 8 et CPU Priority 6 pour les jeux"
                                                    IsChecked="{Binding TwGpuPriority}" Command="{Binding ToggleGpuPriorityCommand}"/>
                                    <local:TweakRow Title="Réactivité système maximale" Sub="SystemResponsiveness=0 pour allouer 100% aux jeux"
                                                    IsChecked="{Binding TwSystemResp}" Command="{Binding ToggleSystemRespCommand}"/>
                                    <local:TweakRow Title="Priorité processus premier plan" Sub="Win32PrioritySeparation=38 pour booster le jeu actif"
                                                    IsChecked="{Binding TwWin32Priority}" Command="{Binding ToggleWin32PriorityCommand}"/>
                                    <local:TweakRow Title="Désactiver accélération souris" Sub="Mouvement souris 1:1 sans interpolation"
                                                    IsChecked="{Binding TwMousePrecision}" Command="{Binding ToggleMousePrecisionCommand}"/>
                                    <local:TweakRow Title="Plan haute performance" Sub="Active le plan d'alimentation Haute Performances"
                                                    IsChecked="{Binding TwHighPerfPlan}" Command="{Binding ToggleHighPerfPlanCommand}"/>
                                    <local:TweakRow Title="Désactiver Network Throttling" Sub="Supprime la limitation réseau Windows Multimedia"
                                                    IsChecked="{Binding TwNetThrottle}" Command="{Binding ToggleNetThrottleCommand}" IsLast="True"/>
                                </StackPanel>
                            </Border>

                            <!-- ══ JEUX DÉTECTÉS ════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="JEUX DÉTECTÉS" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Games}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#12091C" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TxtPrimary}"
                                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" Background="#2D1B4E" CornerRadius="4" Padding="8,3">
                                                            <TextBlock Text="{Binding Source}" FontSize="13"
                                                                       Foreground="{StaticResource AccentLight}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Aucun jeu détecté." Foreground="{StaticResource TxtMuted}" FontSize="12" Margin="0,6,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Games.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- ══ HISTORIQUE DES SESSIONS ══════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="HISTORIQUE DES SESSIONS" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Aucune session enregistrée pour le moment."
                                               FontSize="12" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GameSessions.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding GameSessions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:GameSession}">
                                                <Border Background="#12091C" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding GameName}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TxtPrimary}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DateLabel}" FontSize="12"
                                                                   Foreground="{StaticResource TxtMuted}" VerticalAlignment="Center" Margin="12,0"/>
                                                        <Border Grid.Column="2" Background="#2D1B4E" CornerRadius="4" Padding="8,3">
                                                            <TextBlock Text="{Binding DurationLabel}" FontSize="12"
                                                                       Foreground="{StaticResource AccentLight}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Aucune session enregistrée." Foreground="{StaticResource TxtMuted}" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GameSessions.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 9 — CONFIDENTIALITÉ -->
                    <ScrollViewer x:Name="Tab9Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Confidentialité" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Réduit ce que Windows envoie à Microsoft. Réversible à tout moment. Vos fichiers, mots de passe et données personnelles ne sont jamais touchés." Style="{StaticResource PageSub}"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="PARAMÈTRES VIE PRIVÉE" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TxtMuted}" Margin="0,0,0,12" TextWrapping="Wrap"
                                               Text="Ces options modifient uniquement des paramètres Windows dans le registre. Réversibles à tout moment en recliquant. Vos fichiers et données ne sont jamais affectés."/>
                                    <local:TweakRow Title="Désactiver télémétrie" Sub="Bloque l'envoi de données d'utilisation à Microsoft"
                                                    IsChecked="{Binding TwTelemetry}" Command="{Binding ToggleTelemetryCommand}"/>
                                    <local:TweakRow Title="Désactiver ID publicitaire" Sub="Supprime le profilage publicitaire personnel Windows"
                                                    IsChecked="{Binding TwAdvertisingId}" Command="{Binding ToggleAdvertisingIdCommand}"/>
                                    <local:TweakRow Title="Désactiver géolocalisation" Sub="Bloque l'accès à votre position géographique"
                                                    IsChecked="{Binding TwLocation}" Command="{Binding ToggleLocationCommand}"/>
                                    <local:TweakRow Title="Désactiver Cortana" Sub="Désactive l'assistant vocal Windows"
                                                    IsChecked="{Binding TwCortana}" Command="{Binding ToggleCortanaCommand}"/>
                                    <local:TweakRow Title="Effets visuels minimalistes" Sub="Désactive les animations et effets superflus Windows"
                                                    IsChecked="{Binding TwVisualEffects}" Command="{Binding ToggleVisualEffectsCommand}" IsLast="True"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 10 — SÉCURITÉ -->
                    <ScrollViewer x:Name="Tab10Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Sécurité et restauration" Style="{StaticResource PageTitle}"/>
                                    <TextBlock Text="{Binding SecurityStatus}" Style="{StaticResource PageSub}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource SecBtn}" Margin="0,0,8,0"
                                            Command="{Binding LaunchSystemRestoreCommand}"
                                            Content="↩  Restaurer le système"/>
                                    <Button Style="{StaticResource PrimaryBtn}"
                                            Command="{Binding CreateRestorePointCommand}"
                                            IsEnabled="{Binding IsSecurityBusy, Converter={StaticResource InvBool}}"
                                            Content="💾  Créer un point de restauration"/>
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="POINTS DE RESTAURATION WINDOWS" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <DataGrid ItemsSource="{Binding RestorePoints}" AutoGenerateColumns="False" MaxHeight="400"
                                              IsReadOnly="True" SelectionMode="Single" CanUserResizeRows="False"
                                              CanUserReorderColumns="False" CanUserSortColumns="False"
                                              HeadersVisibility="Column" GridLinesVisibility="None"
                                              Background="Transparent" BorderThickness="0"
                                              RowBackground="Transparent" AlternatingRowBackground="#08FFFFFF">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#9B8BB0"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Foreground" Value="#E0D8F0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#1E1435"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#1E1435"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#"           Binding="{Binding SequenceNumber}" Width="50"/>
                                            <DataGridTextColumn Header="Description" Binding="{Binding Description}"    Width="*"/>
                                            <DataGridTextColumn Header="Date"        Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140"/>
                                            <DataGridTemplateColumn Header="" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="✕ Supprimer"
                                                                Command="{Binding DataContext.DeleteRestorePointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                FontSize="11" Padding="8,4" Margin="4,2"
                                                                Background="#4B1515" Foreground="#FCA5A5"
                                                                BorderThickness="1" BorderBrush="#7F1D1D"
                                                                Cursor="Hand">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}"
                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#7F1D1D"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="Aucun point de restauration." Foreground="{StaticResource TxtMuted}" FontSize="12" Margin="0,10,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RestorePoints.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- ══ BSOD ANALYZER ════════════════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="ANALYSEUR DE CRASHS (BSOD)" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding BsodStatus}" FontSize="12" Foreground="{StaticResource TxtMuted}"
                                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecBtn}" Content="Analyser les crashs"
                                                Command="{Binding RefreshBsodCommand}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding BsodEvents}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:BsodEntry}">
                                                <Border Background="#1A0A0A" CornerRadius="8" Padding="12,8" Margin="0,0,0,5"
                                                        BorderBrush="#4A1515" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Margin="0,0,12,0" Width="120">
                                                            <TextBlock Text="{Binding StopCode}" FontSize="11" FontFamily="Consolas"
                                                                       Foreground="#F87171" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Time, StringFormat=dd/MM/yy HH:mm}" FontSize="10"
                                                                       Foreground="{StaticResource TxtMuted}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="12"
                                                                   Foreground="{StaticResource TxtSecond}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Aucun crash détecté. Votre système est stable ✓" FontSize="12"
                                               Foreground="{StaticResource Success}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BsodEvents.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Background="#130E1F">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" LineHeight="20">
                                    Créez toujours un point de restauration AVANT d'appliquer des optimisations.
                                    Pour restaurer votre PC à un point sauvegardé, cliquez sur "Restaurer le système" — Windows vous guidera pour choisir la date à laquelle revenir.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 11 — AUTOMATISATION -->
                    <ScrollViewer x:Name="Tab11Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Automatisation" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Planifiez des tâches de maintenance automatique." Style="{StaticResource PageSub}"/>
                            <TextBlock Text="{Binding AutomationStatus}" Foreground="{StaticResource AccentLight}" FontSize="12" Margin="0,0,0,16"/>

                            <!-- Bannière mise à jour -->
                            <Border Background="#1C1A04" BorderBrush="#CA8A04" BorderThickness="1" CornerRadius="8"
                                    Padding="14,10" Margin="0,0,0,16"
                                    Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                                <TextBlock Foreground="#FDE047" FontSize="13" FontWeight="SemiBold">
                                    <Run Text="⬆ "/>
                                    <Run Text="{Binding UpdateBanner, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>

                            <UniformGrid Columns="2" Margin="0,0,0,20">
                                <!-- Nettoyage quotidien -->
                                <Border Margin="0,0,8,0" Padding="20,18">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                            <Setter Property="CornerRadius"    Value="10"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCleanScheduled}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                                    <Setter Property="Background"  Value="#0A1A0D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="QUOTIDIEN" Style="{StaticResource MetricLabel}" Margin="0"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                    Visibility="{Binding IsCleanScheduled, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Nettoyage automatique" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,6"/>
                                        <TextBlock Text="Supprime les fichiers temporaires chaque jour à 02h00."
                                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"/>
                                        <Button HorizontalAlignment="Left" IsEnabled="{Binding IsAutoBusy, Converter={StaticResource InvBool}}"
                                                Command="{Binding ToggleDailyCleanupCommand}"
                                                Content="{Binding IsCleanScheduled, Converter={StaticResource BoolText}, ConverterParameter='✗ Annuler la planification|Planifier nettoyage'}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCleanScheduled}" Value="True">
                                                            <Setter Property="Background"  Value="#2E0D0D"/>
                                                            <Setter Property="BorderBrush" Value="#F87171"/>
                                                            <Setter Property="Foreground"  Value="#F87171"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <!-- Analyse hebdomadaire -->
                                <Border Margin="8,0,0,0" Padding="20,18">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                            <Setter Property="CornerRadius"    Value="10"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAnalysisScheduled}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                                    <Setter Property="Background"  Value="#0A1A0D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="HEBDOMADAIRE" Style="{StaticResource MetricLabel}" Margin="0"/>
                                            <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                    Visibility="{Binding IsAnalysisScheduled, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="Analyse hebdomadaire" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,6"/>
                                        <TextBlock Text="Analyse complète chaque dimanche à 03h00."
                                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"/>
                                        <Button HorizontalAlignment="Left" IsEnabled="{Binding IsAutoBusy, Converter={StaticResource InvBool}}"
                                                Command="{Binding ToggleWeeklyAnalysisCommand}"
                                                Content="{Binding IsAnalysisScheduled, Converter={StaticResource BoolText}, ConverterParameter='✗ Annuler la planification|Planifier analyse'}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAnalysisScheduled}" Value="True">
                                                            <Setter Property="Background"  Value="#2E0D0D"/>
                                                            <Setter Property="BorderBrush" Value="#F87171"/>
                                                            <Setter Property="Foreground"  Value="#F87171"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Démarrage automatique avec Windows -->
                            <Border Margin="0,0,0,20" Padding="20,18">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"      Value="{StaticResource BgCard}"/>
                                        <Setter Property="CornerRadius"    Value="10"/>
                                        <Setter Property="BorderBrush"     Value="{StaticResource Border1}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutoStartEnabled}" Value="True">
                                                <Setter Property="BorderBrush" Value="#22C55E"/>
                                                <Setter Property="Background"  Value="#0A1A0D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="DÉMARRAGE WINDOWS" Style="{StaticResource MetricLabel}" Margin="0"/>
                                        <Border HorizontalAlignment="Right" CornerRadius="4" Padding="7,2" Background="#0D2E14"
                                                Visibility="{Binding IsAutoStartEnabled, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="✓ ACTIF" FontSize="10" FontWeight="Bold" Foreground="#22C55E"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Démarrage automatique avec Windows" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TxtPrimary}" Margin="0,2,0,6"/>
                                    <TextBlock Text="L'app se lance discrètement dans la barre de notifications. Le boost gaming est actif dès l'allumage du PC."
                                               TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}" Margin="0,0,0,14"/>
                                    <Button HorizontalAlignment="Left" Command="{Binding ToggleAutoStartCommand}"
                                            Content="{Binding IsAutoStartEnabled, Converter={StaticResource BoolText}, ConverterParameter='✗ Désactiver le démarrage auto|Activer le démarrage auto'}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAutoStartEnabled}" Value="True">
                                                        <Setter Property="Background"  Value="#2E0D0D"/>
                                                        <Setter Property="BorderBrush" Value="#F87171"/>
                                                        <Setter Property="Foreground"  Value="#F87171"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Export rapport système -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RAPPORT SYSTÈME" Style="{StaticResource MetricLabel}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Exporter un rapport complet" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtPrimary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Génère un fichier .html sur le Bureau avec toutes les infos matériel, températures, score PC et problèmes détectés. Idéal pour le support client."
                                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TxtSecond}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0"
                                            Style="{StaticResource SecBtn}" Command="{Binding ExportReportCommand}"
                                            Content="Exporter le rapport"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="TÂCHES PLANIFIÉES ACTIVES" Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ScheduledTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#12091C" CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✓ " Foreground="#22C55E" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TxtPrimary}"
                                                                   FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Aucune tâche planifiée. Utilisez les boutons ci-dessus pour planifier."
                                               Foreground="{StaticResource TxtMuted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ScheduledTasks.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Pour désactiver une tâche, cliquez sur '✗ Annuler la planification' sur la carte correspondante."
                                               FontSize="11" Foreground="{StaticResource TxtMuted}" Margin="0,8,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding IsCleanScheduled, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- TAB 12 — DÉSINSTALLEUR -->
                    <ScrollViewer x:Name="Tab12Panel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28,24,28,24">
                            <TextBlock Text="Désinstalleur d'applications" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Désinstallez proprement et nettoyez les résidus laissés dans le registre et les dossiers."
                                       Style="{StaticResource PageSub}"/>

                            <!-- Barre actions -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#120D1F" CornerRadius="8" Padding="12,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding AppFilter, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent" Foreground="{StaticResource TxtPrimary}"
                                                     BorderThickness="0" FontSize="13" MinWidth="280"
                                                     CaretBrush="{StaticResource AccentLight}"
                                                     VerticalAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter Property="Tag" Value="Rechercher une application…"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                    </Border>
                                    <Button Grid.Column="1" Style="{StaticResource SecBtn}" Margin="10,0,0,0"
                                            Command="{Binding RefreshAppsCommand}"
                                            IsEnabled="{Binding IsUninstallerBusy, Converter={StaticResource InvBool}}"
                                            ToolTip="Recharger la liste des applications installées">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="↻ Actualiser"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUninstallerBusy}" Value="True">
                                                            <Setter Property="Text" Value="Chargement…"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Statut -->
                            <Border Background="#120D1F" CornerRadius="8" Padding="14,10" Margin="0,0,0,12"
                                    BorderBrush="#2D1F45" BorderThickness="1">
                                <TextBlock Text="{Binding UninstallerStatus}" Foreground="{StaticResource TxtSecond}"
                                           FontSize="13"/>
                            </Border>

                            <!-- Liste des apps -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="APPLICATIONS INSTALLÉES" Style="{StaticResource MetricLabel}" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding FilteredApps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type svc:InstalledApp}">
                                                <Border Background="#12091C" CornerRadius="8" Padding="14,10" Margin="0,0,0,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TxtPrimary}"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding Publisher}" FontSize="11"
                                                                           Foreground="{StaticResource TxtMuted}"/>
                                                                <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource TxtMuted}"
                                                                           Visibility="{Binding Publisher, Converter={StaticResource BoolToVis}, ConverterParameter=string}"/>
                                                                <TextBlock Text="{Binding Version}" FontSize="11"
                                                                           Foreground="{StaticResource TxtMuted}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <!-- Taille -->
                                                        <Border Grid.Column="1" Background="#1A1028" CornerRadius="4"
                                                                Padding="8,3" Margin="8,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding SizeLabel}" FontSize="11"
                                                                       Foreground="{StaticResource TxtMuted}"/>
                                                        </Border>
                                                        <!-- Date -->
                                                        <TextBlock Grid.Column="2" Text="{Binding InstallDate}" FontSize="11"
                                                                   Foreground="{StaticResource TxtMuted}" VerticalAlignment="Center"
                                                                   Margin="4,0,8,0"/>
                                                        <!-- Boutons -->
                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource SecBtn}" Padding="10,4" FontSize="12"
                                                                    Content="Désinstaller"
                                                                    ToolTip="Lance le désinstalleur officiel de cette application"
                                                                    Command="{Binding DataContext.UninstallAppCommand,
                                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Cliquez sur '↻ Actualiser' pour charger la liste des applications."
                                               Foreground="{StaticResource TxtMuted}" FontSize="12" FontStyle="Italic"
                                               TextWrapping="Wrap" Margin="0,6,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FilteredApps.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>

            <!-- TOAST -->
            <Border x:Name="ToastBorder" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,24,24" Padding="16,12" CornerRadius="10"
                    Background="#1E1232" BorderBrush="{StaticResource Accent}" BorderThickness="1"
                    Opacity="0" IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="ToastTitle" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentLight}"/>
                    <TextBlock x:Name="ToastMsg"   FontSize="12"
                               Foreground="{StaticResource TxtSecond}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
